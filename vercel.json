{
  "version": 2,
  "name": "grade-ai-system",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api"
    },
    {
      "src": "(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "DATABASE_URL": "@database_url",
    "GROQ_API_KEY": "@groq_api_key",
    "NEXTAUTH_URL": "@nextauth_url",
    "NEXTAUTH_SECRET": "@nextauth_secret",
    "UPLOAD_DIR": "uploads",
    "TEMP_DIR": "temp",
    "MAX_FILE_SIZE": "52428800"
  },
  "functions": {
    "api/ocr.js": {
      "maxDuration": 300
    },
    "api/structured-pdf.js": {
      "maxDuration": 300
    },
    "api/upload.js": {
      "maxDuration": 60
    }
  },
  "build": {
    "env": {
      "NEXTAUTH_URL": "https://grade-ai-system.vercel.app",
      "NEXTAUTH_SECRET": "@nextauth_secret"
    }
  },
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "regions": ["sin1"],
  "provisioning": {
    "database": {
      "type": "postgresql",
      "plan": "free"
    }
  }
}
